# Example environment variable names for this monorepo (no secrets).
# Copy to `.env` or export in your shell. See docs/configuration.md for semantics.

# --- GSD feature flags (boolean: 1, true, yes case-insensitive) ---
# GSD_BEDROCK_ASSUME_DEFAULT_CREDS=
# GSD_MCP_TOOLS_ROOT=
# GSD_DOCKER_SMOKE=
# GSD_SHELL_HOOKS_ENABLED=
# GSD_LEARN_OVERLAY_DIR=
# GSD_PROVIDER_PAYLOAD_LOGGING=

# --- Provider / tooling passthrough (do not strip from children / Vite) ---
# GROQ_API_KEY=
# E2B_API_KEY=
# STRIPE_SECRET_KEY=
# VERCEL_API_TOKEN=
# VITE_LAUNCHDARKLY_SDK_KEY=
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
