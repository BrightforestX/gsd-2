# ── Mastra + Vite (React_flow_test) ─────────────────────────────────────────
# Model provider API keys belong on the Mastra Node server ONLY (e.g. mastra dev / your deploy).
# Do NOT prefix provider secrets with VITE_ — they would be exposed in the browser bundle.

# Where `npm run dev` proxies /api/mastra/* (server-side, read by vite.config.js)
# If another Mastra instance is running, `mastra dev` may use 4112+ — match MASTRA_SERVER_URL to its log.
MASTRA_SERVER_URL=http://127.0.0.1:4111

# Browser-visible: path joined to build the chat POST URL (proxied in dev)
VITE_MASTRA_CHAT_BASE=/api/mastra
# Mastra `chatRoute({ path: '/chat/:agentId' })` lives at the server ROOT (not under /api).
# Vite maps /api/mastra + this path → http://MASTRA_SERVER_URL/chat/...
VITE_MASTRA_CHAT_PATH=/chat/gsdSchemaAgent

# Optional: call Mastra directly (no proxy), e.g. production UI on another host
# VITE_MASTRA_CHAT_BASE=https://your-mastra-host
# VITE_MASTRA_CHAT_PATH=/chat/gsdSchemaAgent

# On the Mastra project (not this Vite app), set the provider you use, for example:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# GROQ_API_KEY=
